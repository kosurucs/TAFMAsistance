# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=           # populated automatically after login
KITE_TOTP_SECRET=your_totp_secret_here   # Base-32 TOTP secret from Zerodha 2FA
KITE_USER_ID=your_zerodha_user_id        # used by automated TOTP login flow

# ── Instruments Cache (data connection layer) ─────────────────────────────────
# Directory where per-exchange instruments CSVs are cached (refreshed daily).
INSTRUMENTS_CACHE_DIR=data/instruments_cache

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Path to fine-tuned LoRA adapter weights (relative to project root)
LLM_MODEL_PATH=models/trading-lora-adapter
# HuggingFace model id used as the base (if no local weights yet)
LLM_BASE_MODEL=meta-llama/Meta-Llama-3-8B

# ── Redis (State Memory) ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── TimescaleDB (Trade Logs) ──────────────────────────────────────────────────
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=trading_logs
TIMESCALE_USER=trader
TIMESCALE_PASSWORD=changeme

# ── Risk Management ───────────────────────────────────────────────────────────
# Maximum intraday loss as a fraction of opening capital (e.g. 0.02 = 2 %)
MAX_DAILY_LOSS_PCT=0.02
# Maximum single-trade size as a fraction of portfolio value
MAX_POSITION_SIZE_PCT=0.05

# ── Paper Trading Toggle ──────────────────────────────────────────────────────
# Set to "true" to run without hitting the live Zerodha API
PAPER_TRADING=true

# ── Target Instruments ────────────────────────────────────────────────────────
# Comma-separated list of NSE/BSE instrument tokens or tradingsymbols
WATCHLIST=RELIANCE,INFY,TCS,HDFCBANK

# ── API Server ────────────────────────────────────────────────────────────────
# Host and port for the FastAPI backend (uvicorn)
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit Dashboard ───────────────────────────────────────────────────────
DASHBOARD_PORT=8501
# URL the dashboard uses to reach the API (override inside Docker)
API_BASE_URL=http://localhost:8000
